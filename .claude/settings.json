{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "allowlister hook claude-code",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "allowlister hook claude-code",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|Glob|Grep|WebFetch|WebSearch|NotebookEdit|mcp__.*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR}/scripts/session-setup.sh\"",
            "timeout": 120,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(just)",
      "Bash(just:*)",
      "Bash(uv run cloud-agent-dev-env:*)",
      "Bash(scripts/session-setup.sh:*)",
      "Bash(scripts/setup-llmlint.sh)",
      "Bash(llmlint:*)",
      "Bash(just lint-llm-validate:*)",
      "Bash(just lint-llm-diff:*)",
      "Bash(just lint-llm:*)",
      "Bash(just setup-llmlint)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh auth status)",
      "Bash(gh repo view:*)",
      "Bash(gh skill install nickderobertis/dero-skills:*)",
      "Bash(gh skill update:*)",
      "Bash(allowlister init:*)",
      "Bash(oneharness detect:*)",
      "Read(.cache/uv/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)"
    ]
  }
}
