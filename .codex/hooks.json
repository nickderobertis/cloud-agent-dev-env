{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "allowlister hook codex",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "allowlister hook codex",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Read|Edit|Write|Glob|Grep|WebFetch|WebSearch|NotebookEdit|mcp__.*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash .codex/hooks/session-start.sh",
            "timeout": 120,
            "type": "command"
          }
        ]
      }
    ]
  }
}
